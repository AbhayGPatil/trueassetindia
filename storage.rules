rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read access to everything
    match /{allPaths=**} {
      allow read: if true;
    }
    
    // Authenticated write access to everything
    match /{allPaths=**} {
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }
  }
}
