rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow authenticated users to upload property images and videos
    match /properties/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Allow authenticated users to upload profile images
    match /profiles/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Allow authenticated users to upload developer project images and videos
    // Path: developer-projects/{uid}/{filename}
    match /developer-projects/{userId}/{filename} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth.uid == userId;
    }

    // Allow authenticated users to upload under developer-projects subdirectories
    match /developer-projects/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
      allow delete: if request.auth.uid == userId;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
