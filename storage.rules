rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Allow public read access to all files
    match /{allPaths=**} {
      allow read: if true;
    }

    // Allow authenticated users to write to properties
    match /properties/{allPaths=**} {
      allow write, delete: if request.auth != null;
    }

    // Allow authenticated users to write to profiles
    match /profiles/{allPaths=**} {
      allow write, delete: if request.auth != null;
    }

    // Allow authenticated users to write to developer-projects - Most permissive rule
    match /developer-projects/{allPaths=**} {
      allow write: if request.auth != null;
      allow delete: if request.auth != null;
    }

    // Catch-all deny for other paths
    match /{allPaths=**} {
      allow write, delete: if false;
    }
  }
}
